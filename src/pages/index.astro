---
import BaseLayout from '../layouts/BaseLayout.astro';
import Calculator from '../components/Calculator';
import FaraidGuide from '../components/FaraidGuide.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "KiraFaraid - Kalkulator Faraid Malaysia",
  "url": "https://www.kirafaraid.my",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "MYR"
  },
  "description": "Kalkulator Faraid Islam profesional mengikut hukum Shafi'i Malaysia. Kira pembahagian harta pusaka mengikut hukum Islam dengan pengiraan Faraid yang tepat.",
  "inLanguage": "ms",
  "creator": {
    "@type": "Organization",
    "name": "KiraFaraid"
  }
};
---

<BaseLayout
  title="Kalkulator Faraid Malaysia - Kira Pembahagian Harta Pusaka Percuma"
  description="Kalkulator Faraid Islam profesional mengikut hukum Shafi'i Malaysia. Kira pembahagian harta pusaka mengikut hukum Islam dengan pengiraan Faraid yang tepat."
  jsonLd={jsonLd}
>
  <Calculator client:load />

  <!-- Quick Links Section -->
  <div class="mt-16 max-w-2xl mx-auto">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <a href="/panduan-faraid" class="flex flex-col items-center gap-2 p-4 bg-white rounded-xl border border-slate-100 hover:border-emerald-200 hover:bg-emerald-50/50 transition group no-underline">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-slate-400 group-hover:text-emerald-600 transition"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        <span class="text-xs font-medium text-slate-600 group-hover:text-emerald-700 transition">Panduan Faraid</span>
      </a>
      <a href="/hubungi" class="flex flex-col items-center gap-2 p-4 bg-white rounded-xl border border-slate-100 hover:border-emerald-200 hover:bg-emerald-50/50 transition group no-underline">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-slate-400 group-hover:text-emerald-600 transition"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        <span class="text-xs font-medium text-slate-600 group-hover:text-emerald-700 transition">Hubungi Kami</span>
      </a>
      <a href="/dasar-privasi" class="flex flex-col items-center gap-2 p-4 bg-white rounded-xl border border-slate-100 hover:border-emerald-200 hover:bg-emerald-50/50 transition group no-underline">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-slate-400 group-hover:text-emerald-600 transition"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span class="text-xs font-medium text-slate-600 group-hover:text-emerald-700 transition">Dasar Privasi</span>
      </a>
      <a href="/terma-perkhidmatan" class="flex flex-col items-center gap-2 p-4 bg-white rounded-xl border border-slate-100 hover:border-emerald-200 hover:bg-emerald-50/50 transition group no-underline">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-slate-400 group-hover:text-emerald-600 transition"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        <span class="text-xs font-medium text-slate-600 group-hover:text-emerald-700 transition">Terma Perkhidmatan</span>
      </a>
    </div>
  </div>

  <!-- Artikel Berkaitan Section -->
  <div class="mt-16 max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-slate-800 text-center mb-2">Artikel Berkaitan Faraid</h2>
    <p class="text-slate-500 text-center text-sm mb-8">Baca panduan dan artikel lengkap mengenai hukum Faraid di Malaysia.</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Senario Kematian -->
      <div class="bg-white rounded-xl border border-slate-100 p-5">
        <h3 class="font-semibold text-emerald-800 text-sm mb-3">Senario Kematian</h3>
        <ul class="space-y-2">
          <li><a href="/faraid-suami-meninggal" class="text-sm text-slate-600 hover:text-emerald-600 transition">Faraid Suami Meninggal</a></li>
          <li><a href="/faraid-ayah-meninggal" class="text-sm text-slate-600 hover:text-emerald-600 transition">Faraid Ayah Meninggal</a></li>
          <li><a href="/faraid-ibu-meninggal" class="text-sm text-slate-600 hover:text-emerald-600 transition">Faraid Ibu Meninggal</a></li>
        </ul>
      </div>

      <!-- Panduan & Rujukan -->
      <div class="bg-white rounded-xl border border-slate-100 p-5">
        <h3 class="font-semibold text-emerald-800 text-sm mb-3">Panduan & Rujukan</h3>
        <ul class="space-y-2">
          <li><a href="/apa-itu-faraid" class="text-sm text-slate-600 hover:text-emerald-600 transition">Apa Itu Faraid?</a></li>
          <li><a href="/panduan-faraid" class="text-sm text-slate-600 hover:text-emerald-600 transition">Panduan Faraid Lengkap</a></li>
          <li><a href="/jadual-pembahagian-faraid" class="text-sm text-slate-600 hover:text-emerald-600 transition">Jadual Pembahagian Faraid</a></li>
          <li><a href="/pembahagian-harta-mengikut-faraid" class="text-sm text-slate-600 hover:text-emerald-600 transition">Pembahagian Harta Mengikut Faraid</a></li>
        </ul>
      </div>

      <!-- Topik Khas -->
      <div class="bg-white rounded-xl border border-slate-100 p-5">
        <h3 class="font-semibold text-emerald-800 text-sm mb-3">Topik Khas</h3>
        <ul class="space-y-2">
          <li><a href="/faraid-anak-lelaki-dan-perempuan" class="text-sm text-slate-600 hover:text-emerald-600 transition">Faraid Anak Lelaki dan Perempuan</a></li>
          <li><a href="/harta-sepencarian" class="text-sm text-slate-600 hover:text-emerald-600 transition">Harta Sepencarian</a></li>
          <li><a href="/cara-pengiraan-faraid-kwsp" class="text-sm text-slate-600 hover:text-emerald-600 transition">Cara Pengiraan Faraid KWSP</a></li>
          <li><a href="/faraid-selangor" class="text-sm text-slate-600 hover:text-emerald-600 transition">Faraid Selangor</a></li>
          <li><a href="/faraid-johor" class="text-sm text-slate-600 hover:text-emerald-600 transition">Faraid Johor</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div id="guide" class="mt-24 max-w-4xl mx-auto">
    <FaraidGuide />
  </div>
</BaseLayout>
