---
import BaseLayout from '../layouts/BaseLayout.astro';
import Calculator from '../components/Calculator';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Kalkulator Faraid Johor - Pembahagian Harta Pusaka Islam Johor",
  "description": "Kalkulator Faraid untuk penduduk Johor. Pengiraan pembahagian harta pusaka mengikut hukum Faraid Islam yang ditadbir oleh MAINJ (Majlis Agama Islam Negeri Johor).",
  "inLanguage": "ms",
  "publisher": { "@type": "Organization", "name": "KiraFaraid", "url": "https://www.kirafaraid.my" }
};
---

<BaseLayout
  title="Kalkulator Faraid Johor - Pembahagian Harta Pusaka Islam MAINJ"
  description="Kalkulator Faraid untuk penduduk Johor. Pengiraan pembahagian harta pusaka mengikut hukum Faraid Islam yang ditadbir oleh MAINJ."
  jsonLd={jsonLd}
>
  <article class="max-w-4xl mx-auto space-y-12">
    <header class="text-center space-y-4">
      <h1 class="text-4xl font-bold text-warm-800">Kalkulator Faraid Johor</h1>
      <p class="text-lg text-warm-600 max-w-2xl mx-auto">Pengiraan pembahagian harta pusaka Islam untuk penduduk negeri Johor mengikut Mazhab Syafi'i.</p>
    </header>

    <div class="bg-white rounded-2xl shadow-sm border border-warm-200 p-6 md:p-10 prose prose-slate max-w-none">
      <h2 class="text-2xl font-bold text-teal-800">Faraid di Johor</h2>
      <p>Seperti negeri-negeri lain di Malaysia, Johor menggunakan hukum Faraid berdasarkan <strong>Mazhab Syafi'i</strong>. Pengiraan bahagian waris adalah sama di seluruh Malaysia kerana bersumberkan Al-Quran dan Hadis.</p>

      <h2 class="text-2xl font-bold text-teal-800 mt-8">Institusi Berkaitan di Johor</h2>
      <ul>
        <li><strong>MAINJ (Majlis Agama Islam Negeri Johor)</strong> — Badan yang mentadbir hal ehwal agama Islam di Johor.</li>
        <li><strong>Mahkamah Syariah Johor</strong> — Mengeluarkan Sijil Faraid dan memutuskan kes harta sepencarian.</li>
        <li><strong>Pejabat Tanah Daerah</strong> — Untuk urusan pindah milik hartanah.</li>
        <li><strong>Amanah Raya Berhad</strong> — Mentadbir harta pusaka kecil di seluruh Malaysia.</li>
      </ul>

      <h2 class="text-2xl font-bold text-teal-800 mt-8">Proses Tuntutan Harta Pusaka di Johor</h2>
      <ol>
        <li>Dapatkan Sijil Kematian dari JPN.</li>
        <li>Mohon Sijil Faraid di Mahkamah Syariah Johor.</li>
        <li>Untuk harta pusaka kecil, mohon di Unit Pembahagian Pusaka Kecil.</li>
        <li>Untuk harta besar atau melibatkan hartanah, mohon di Mahkamah Tinggi.</li>
      </ol>

      <div class="bg-blue-50 p-6 rounded-xl border border-blue-200 not-prose mt-6">
        <h3 class="font-bold text-blue-800 mb-2">Pengiraan Faraid Sama di Seluruh Malaysia</h3>
        <p class="text-sm text-blue-800/80">Hukum Faraid adalah seragam di semua negeri. Kalkulator KiraFaraid boleh digunakan untuk mengira pembahagian harta pusaka di Johor, Selangor, atau mana-mana negeri di Malaysia.</p>
      </div>
    </div>

    <div class="space-y-4">
      <h2 class="text-2xl font-bold text-warm-800 text-center">Kira Pembahagian Faraid</h2>
      <p class="text-warm-600 text-center">Gunakan kalkulator di bawah untuk mengira pembahagian harta pusaka anda.</p>
      <Calculator client:visible embedded />
    </div>

    <div class="text-center text-sm text-warm-500 space-x-4">
      <a href="/" class="text-teal-600 hover:underline">Kalkulator Faraid</a>
      <span>&middot;</span>
      <a href="/faraid-selangor" class="text-teal-600 hover:underline">Faraid Selangor</a>
      <span>&middot;</span>
      <a href="/panduan-faraid" class="text-teal-600 hover:underline">Panduan Faraid</a>
      <span>&middot;</span>
      <a href="/jadual-pembahagian-faraid" class="text-teal-600 hover:underline">Jadual Pembahagian Faraid</a>
      <span>&middot;</span>
      <a href="/apa-itu-faraid" class="text-teal-600 hover:underline">Apa Itu Faraid?</a>
      <span>&middot;</span>
      <a href="/harta-sepencarian" class="text-teal-600 hover:underline">Harta Sepencarian</a>
    </div>
  </article>
</BaseLayout>
